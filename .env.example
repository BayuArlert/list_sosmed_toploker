# Salin ke .env untuk development lokal
PORT=3000
SPREADSHEET_ID=your_spreadsheet_id_here

# Opsional lokal: pakai file credentials.json saja
# Untuk Railway: wajib set GOOGLE_CREDENTIALS (isi penuh JSON service account, 1 baris)
# GOOGLE_CREDENTIALS={"type":"service_account",...}

# Opsional: cookies Instagram (JSON array) agar tidak login ulang setelah redeploy
# IG_COOKIES_JSON=[{"name":"sessionid",...}]
